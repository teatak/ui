{
    "compilerOptions": {
        "module": "esnext",
        "target": "es2015",
        "lib": [
            "dom",
        ],
        "allowJs": true,
        "sourceMap": true,
        "jsx": "react",
        "moduleResolution": "node",
        "noImplicitReturns": true,
        "noImplicitThis": true,
        "noImplicitAny": true,
        "strictNullChecks": true,
        "esModuleInterop": true,
    },
    "include": [
        "src/**/*",
    ],
    "exclude": [
        "node_modules",
        "build",
        "dist",
    ]
}