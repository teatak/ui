{
  "name": "@teatak/ui",
  "version": "1.2.73",
  "description": "teatak ui",
  "license": "MIT License",
  "main": "dist/lib/index.js",
  "module": "dist/es/index.js",
  "sideEffects": [
    "*.css"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/teatak/ui.git"
  },
  "scripts": {
    "clean:es": "rimraf dist/es",
    "clean:commonjs": "rimraf dist/lib",
    "clean:product": "rimraf docs/*.js docs/*.css docs/*.txt docs/*.html",
    "watch": "cross-env NODE_ENV=dev webpack --config webpack.config.js --mode=development -w",
    "build:es": "babel src/ --out-dir dist/es/ --copy-files",
    "build:commonjs": "babel src/ --out-dir dist/lib/ --plugins @babel/plugin-transform-modules-commonjs --copy-files",
    "build:product": "cross-env NODE_ENV=prod webpack --config webpack.config.js --mode=production --progress",
    "build": "npm-run-all clean:* --parallel build:*",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@babel/cli": "^7.23.4",
    "@babel/core": "^7.23.7",
    "@babel/preset-react": "^7.23.3",
    "@emotion/babel-plugin": "^11.11.0",
    "@emotion/react": "^11.11.3",
    "@loadable/component": "^5.16.3",
    "babel-loader": "^9.1.3",
    "color": "^4.2.3",
    "cross-env": "^7.0.3",
    "html-webpack-plugin": "^5.6.0",
    "npm-run-all": "^4.1.5",
    "nprogress": "^0.2.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet": "^6.1.0",
    "react-router-dom": "^6.21.2",
    "rimraf": "^5.0.5",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
