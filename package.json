{
  "name": "@teatak/ui",
  "version": "1.2.73",
  "description": "teatak ui",
  "license": "MPL-2.0",
  "main": "dist/lib/index.js",
  "module": "dist/es/index.js",
  "sideEffects": [
    "*.css"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/teatak/ui.git"
  },
  "scripts": {
    "clean:commonjs": "rimraf lib",
    "clean:product": "rimraf docs/*.js docs/*.css docs/*.txt docs/*.html",
    "clean:es": "rimraf es",
    "watch": "cross-env NODE_ENV=dev webpack --config webpack.config.js --mode=development -w",
    "build:product": "cross-env NODE_ENV=prod webpack --config webpack.config.js --mode=production --progress",
    "build:commonjs": "babel src/ --out-dir dist/lib/ --plugins @babel/plugin-transform-modules-commonjs --copy-files --ignore **/__tests__,**/__mocks__",
    "build:es": "babel src/ --out-dir dist/es/ --copy-files --ignore **/__tests__,**/__mocks__",
    "build": "npm-run-all clean:* --parallel build:*",
    "prepack": "npm run build"
  },
  "devDependencies": {
    "@babel/cli": "^7.23.4",
    "@babel/core": "^7.23.7",
    "@babel/plugin-proposal-class-properties": "^7.13.0",
    "@babel/plugin-syntax-dynamic-import": "^7.8.3",
    "@babel/plugin-transform-runtime": "^7.23.7",
    "@babel/preset-env": "^7.23.7",
    "@babel/preset-react": "^7.23.3",
    "@emotion/css": "^11.11.2",
    "@emotion/react": "^11.11.3",
    "babel-loader": "^9.1.3",
    "babel-plugin-import": "^1.13.8",
    "cross-env": "^7.0.3",
    "css-loader": "^6.8.1",
    "html-webpack-plugin": "^5.6.0",
    "less": "^4.2.0",
    "less-loader": "^11.1.4",
    "mini-css-extract-plugin": "^2.7.6",
    "npm-run-all": "^4.1.5",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-helmet": "^6.1.0",
    "rimraf": "^5.0.5",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "peerDependencies": {
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0"
  }
}
